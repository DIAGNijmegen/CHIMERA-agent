# ============================================================================
# LLM-Biopsy-Decision Evaluator — environment configuration
#
# Copy this file to .env and adjust for your system.
# The Makefile loads .env automatically.  You can also export any of these
# in your shell before running `make`.
# ============================================================================

# ── GPU ──────────────────────────────────────────────────────────────────────

# Which GPU index to expose to the container (check available GPUs with
# `nvidia-smi`).  Comment-out / unset for a CPU-only run, and also set
# USE_RATIONALE_JUDGE=0 below.
GPU_DEVICE_ID=0

# ── Mount paths (host side) ─────────────────────────────────────────────────

# Read-only inputs (target.json, evaluation_object.json,
# section_variable_mapping.json).  Default = ./mimic_datasets/.
# INPUT_DIR=/path/to/my-inputs

# Writable results directory.  Default = ./results/.
# OUTPUT_DIR=/path/to/my-results

# Persistent Ollama weight store.  Default = ./models/.
# Point this at a pre-populated directory to skip the model download
# (and to run fully offline on Grand Challenge).
# OLLAMA_MODELS_DIR=/mnt/shared/ollama_models

# ── Judge LLM ────────────────────────────────────────────────────────────────

# Ollama model tag used as the rationale judge.
#   gemma4:e4b   — ~9.6 GB, fits a 24 GB GPU (default)
#   gemma4:27b   — ~18 GB, higher quality, needs >= 32 GB VRAM
JUDGE_MODEL=gemma4:e4b

# Set to 0 to skip the LLM-judge step (fully deterministic, no GPU required).
USE_RATIONALE_JUDGE=1

# Set to 0 to FORBID pulling weights at runtime — entrypoint will fail fast
# if the model is missing from /models.  Use this for offline / Grand-Challenge
# submissions; combine with `make pull-model` to populate ./models/ first.
ALLOW_MODEL_PULL=1

# ── Shared-host namespacing (optional) ──────────────────────────────────────

# Prefix container names to avoid clashes when multiple users run this on
# the same host.  Default = "biopsy-eval".
# COMPOSE_NAME_PREFIX=myname
