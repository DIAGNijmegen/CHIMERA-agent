# ============================================================================
# LLM-Evaluator — environment configuration
#
# Copy this file to .env and adjust for your system.
# The Makefile loads .env automatically.
# You can also export any of these in your shell before running make.
# ============================================================================

# ── GPU / Ollama ──────────────────────────────────────────────────────────────

# Which GPU (by index) to expose to the Ollama container.
# Check available GPUs with:  nvidia-smi
GPU_DEVICE_ID=0

# Host port for the Ollama HTTP API.
# Change if port 11434 is already used on your machine.
OLLAMA_HOST_PORT=11434

# Where to cache Ollama model weights on the host.
# LEAVE UNSET to use the default: <repo-root>/models/   (created automatically)
# On a shared server with weights already downloaded, point here instead:
# OLLAMA_MODELS_DIR=/mnt/shared/ollama_models
# OLLAMA_MODELS_DIR=/home/user/.ollama

# Judge model to use.
#   gemma4:e4b   — ~9.6 GB download, fits a 24 GB RTX 3090 or A10
#   gemma4:27b   — ~18 GB download, needs >= 32 GB VRAM  (higher quality)
JUDGE_MODEL=gemma4:e4b

# ── Evaluation I/O (rarely need changing) ───────────────────────────────────

# Paths are resolved inside the container (/app maps to the repo root).
TARGET_FILE=/app/mimic_datasets/target.json
EVAL_FILE=/app/mimic_datasets/evaluation_object.json
EVAL_OUTPUT_DIR=/app/results

# Set to 0 to skip the LLM-judge step and run fully deterministic metrics.
# Useful for fast smoke tests or when no GPU is available.
USE_RATIONALE_JUDGE=1

# ── Shared-host namespacing (optional) ───────────────────────────────────────

# Prefix Docker container names to avoid clashes when multiple users run this
# on the same host.  Defaults to "deepeval".
# COMPOSE_NAME_PREFIX=myname
