# Copy to `.env` and tweak per-user before running compose:
#   cp docker/.env.example docker/.env
#   sed -i "s/^HOST_UID=.*/HOST_UID=$(id -u)/; s/^HOST_GID=.*/HOST_GID=$(id -g)/" docker/.env

# --- Per-user namespacing (avoid clashes on shared host) -------------------
# Container names will be: ${COMPOSE_NAME_PREFIX}_ollama_${USER}, etc.
COMPOSE_NAME_PREFIX=deepeval
# COMPOSE_PROJECT_NAME also namespaces networks/volumes; defaults to dir name.
# COMPOSE_PROJECT_NAME=deepeval_navvin

# --- Host port for the ollama HTTP API (must be unique per running stack) --
# Pick something unlikely to clash; the default 11434 is what stand-alone
# ollama uses, so on a shared host you almost certainly want to change it.
OLLAMA_HOST_PORT=21434

# --- GPU selection ---------------------------------------------------------
# Run `nvidia-smi` first; pick a GPU that is free.
GPU_DEVICE_ID=0

# --- File ownership for results/ ------------------------------------------
HOST_UID=1000
HOST_GID=1000

# --- Model + cache --------------------------------------------------------
JUDGE_MODEL=gemma4:e4b
OLLAMA_MODELS_DIR=/mnt/mebprostateai/projects/patho_vlm/pretrained_models
